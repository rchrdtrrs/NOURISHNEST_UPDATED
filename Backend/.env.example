SECRET_KEY=django-insecure-dev-only-key-do-not-use-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Leave blank to use SQLite (default). For Postgres: postgres://user:pass@localhost:5432/nourishnest
DATABASE_URL=

# OpenRouter AI — https://openrouter.ai/keys
OPENROUTER_API_KEY=
OPENROUTER_DEFAULT_MODEL=openai/gpt-4o-mini

# CORS — add any frontend dev port you use
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,http://127.0.0.1:3000

# AI generation rate limits (requests per day per tier)
DAILY_LIMIT_FREE=5
DAILY_LIMIT_PREMIUM=50
DAILY_LIMIT_PRO=100

# PayPal — https://developer.paypal.com/dashboard
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_MODE=sandbox
PAYPAL_WEBHOOK_ID=
